# Create .env file in the main directory of this project and copy the content.
# Define the below variables to fit your needs.

# the location as string; for immowelt use the POCODE or AD08DE format, e.g. AD08DE2812
# (place IDs can be found in immowelt search URLs, or use a German city name as fallback)
LOCATION=
ZIP_CODE=

# the upper price limit in €, e.g. 700000
PRICE_UPPER_LIMIT=

# radius defined in kilometer
RADIUS=

# enable / disable specific platforms (true / false)
IMMOSCOUT_ENABLED=true
IMMOWELT_ENABLED=true
KLEINANZEIGEN_ENABLED=true
VR_IMMOBILIEN_ENABLED=true
SPARKASSE_ENABLED=true

# set weights for rating characteristica, must sum up to 1
PRICE_WEIGHT=
LIVING_AREA_WEIGHT=
LAND_AREA_WEIGHT=
DISTANCE_WEIGHT=